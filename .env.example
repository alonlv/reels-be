# ---- Database ----
DATABASE_URL=postgresql+psycopg2://reels:reels@localhost:5432/reels
# Managed Postgres (e.g. Azure Database for PostgreSQL) usually requires TLS:
# DB_SSLMODE=require
# DB_POOL_PRE_PING=true

# ---- LLM provider ----
# ollama | openai | anthropic | azure_openai | azure_function
MODEL_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma2:2b
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# Azure OpenAI / Azure AI Foundry (MODEL_PROVIDER=azure_openai):
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=<your deployment name>
# AZURE_OPENAI_API_VERSION=2024-12-01-preview
# Azure Function used as an LLM gateway (MODEL_PROVIDER=azure_function):
# AZURE_FUNCTION_URL=https://<app>.azurewebsites.net/api/llm
# AZURE_FUNCTION_KEY=

# ---- Auth ----
# Users are managed by SSO (Azure AD / Entra ID). PASSWORD_AUTH_ENABLED is the
# feature flag that re-enables the legacy name + admin-password fallback.
SSO_ENABLED=true
PASSWORD_AUTH_ENABLED=true
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# SSO_SCOPES=openid profile email
# SSO_USERINFO_URL=https://graph.microsoft.com/oidc/userinfo
# Comma-separated emails granted admin when they sign in via SSO:
# ADMIN_EMAILS=you@yourcompany.com
# ADMIN_PASSWORD=admin

CORS_ORIGINS=http://localhost:5173
SCAN_ENABLED=true
SCAN_CRON=0 * * * *
X_SYNC_INTERVAL_HOURS=6
# X_BEARER_TOKEN=
# X-sync also requires real numeric x_user_ids in x_accounts.config.json
# (the shipped placeholders are "REPLACE_WITH_NUMERIC_ID") plus X_BEARER_TOKEN set above.
