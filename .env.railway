# Railway Environment Configuration
# This is an example - customize with your actual values

# Database (Railway PostgreSQL plugin)
# DATABASE_URL will be automatically provided by Railway PostgreSQL
# or set it to your managed database connection string
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/reels

# LLM Configuration
MODEL_PROVIDER=ollama

# IMPORTANT: For Railway deployments where Ollama runs locally/separately:
# Use your Ollama server address (could be local machine, another service, etc.)
# If Ollama is on your local machine and you're using Railway, you'll need to expose it
# OLLAMA_BASE_URL=http://your-ollama-server:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:2b

# Alternative: Use Claude (Anthropic) - uncomment and add your API key
# MODEL_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Alternative: Use ChatGPT (OpenAI) - uncomment and add your API key
# MODEL_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# CORS Configuration - Update with your frontend URL
CORS_ORIGINS=http://localhost:5173,https://your-frontend-domain.com

# Scanning Configuration
SCAN_ENABLED=true
SCAN_CRON=0 * * * *
X_SYNC_INTERVAL_HOURS=6

# X (Twitter) Integration - Optional
# X_BEARER_TOKEN=your_x_bearer_token_here
