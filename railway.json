{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "./entrypoint.sh",
    "restartPolicyType": "always",
    "restartPolicyMaxRetries": 5
  },
  "features": {
    "postDeploy": "python -c \"from app.db import migrate; migrate()\""
  }
}
